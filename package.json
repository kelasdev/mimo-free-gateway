{
  "name": "mimo-free-gateway",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Gateway proxy for MiMo Free API — agent CLI cukup arahkan base URL ke sini",
  "main": "gateway.js",
  "scripts": {
    "start": "node gateway.js",
    "start:dev": "node --watch gateway.js",
    "check": "node proxy-checker.js",
    "check:verbose": "node proxy-checker.js --verbose",
    "check:json": "node proxy-checker.js --json --no-output"
  },
  "dependencies": {
    "https-proxy-agent": "^9.1.0",
    "socks": "^2.8.9",
    "socks-proxy-agent": "^10.1.0"
  }
}
